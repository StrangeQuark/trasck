# Local-only example configuration.
# Copy to .env for development; do not commit real secrets.

SPRING_APPLICATION_NAME=trasck
SERVER_PORT=6100
CORS_ALLOWED_ORIGINS=http://localhost:8080

SPRING_DATASOURCE_URL=jdbc:postgresql://trasck-db:5432/trasck
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
POSTGRES_USER=trasck
POSTGRES_PASSWORD=replace-with-local-db-password
POSTGRES_DB=trasck

SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SPRING_JPA_OPEN_IN_VIEW=false

# Local values may be generated with:
# openssl rand -base64 48
TRASCK_JWT_SECRET=replace-with-at-least-32-characters
TRASCK_SECRETS_ENCRYPTION_KEY=replace-with-at-least-32-characters
TRASCK_OAUTH_ASSERTION_SECRET=replace-with-at-least-32-characters
TRASCK_AUTH_COOKIE_SECURE=false
TRASCK_OAUTH_SUCCESS_REDIRECT=http://localhost:8080/auth/callback
TRASCK_TRUST_FORWARDED_FOR=false

# Comma-separated host or host:port entries for trusted self-hosted outbound targets.
# Keep empty unless a local webhook, worker, or S3-compatible endpoint is intentionally trusted.
TRASCK_OUTBOUND_URL_ALLOWED_HOSTS=

SPRING_MAIL_HOST=maildev
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
TRASCK_EMAIL_PROVIDER=maildev
TRASCK_EMAIL_FROM=no-reply@trasck.local
