# App and server config
SPRING_APPLICATION_NAME=trasck
SERVER_PORT=6100
CORS_ALLOWED_ORIGINS=http://localhost:8080

# DB Config
SPRING_DATASOURCE_URL=jdbc:postgresql://trasck-db:5432/trasck
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=trasck

# JPA / Hibernate
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SPRING_JPA_OPEN_IN_VIEW=false

# Secret keys
# Generate this secret key with the following linux shell command: head /dev/urandom | tr -dc A-F0-9 | head -c32
TRASCK_JWT_SECRET=dev-only-change-me-dev-only-change-me-dev-only-change-me-32
TRASCK_SECRETS_ENCRYPTION_KEY=9F3C7A1E6B84D2C5F0A19E3B7D6C4281
