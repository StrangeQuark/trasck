GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/export-jobs/{{exportJobId}}/download
Authorization: Bearer {{accessToken}}

### Create Generic Worker Agent Provider
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-providers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "providerKey": "worker-local",
  "providerType": "generic_worker",
  "displayName": "Generic Worker",
  "dispatchMode": "polling",
  "enabled": true
}

### Create Codex CLI Agent Provider
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-providers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "providerKey": "codex-local",
  "providerType": "codex",
  "displayName": "Codex Local",
  "dispatchMode": "managed",
  "enabled": true,
  "config": {
    "runtime": {
      "mode": "cli_worker",
      "externalExecutionEnabled": true,
      "cliWorker": {
        "commandProfile": "codex-local"
      }
    }
  }
}

### Create Claude Code CLI Agent Provider
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-providers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "providerKey": "claude-code-local",
  "providerType": "claude_code",
  "displayName": "Claude Code Local",
  "dispatchMode": "managed",
  "enabled": true,
  "config": {
    "runtime": {
      "mode": "cli_worker",
      "externalExecutionEnabled": true,
      "cliWorker": {
        "commandProfile": "claude-code-local"
      }
    }
  }
}

### Create Worker Token Credential
POST {{baseUrl}}/api/v1/agent-providers/{{providerId}}/credentials
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "credentialType": "worker_token",
  "secret": "{{agentWorkerToken}}",
  "metadata": {
    "workerId": "worker-1",
    "purpose": "generic-worker-auth"
  }
}

### Create Codex API Key Credential
POST {{baseUrl}}/api/v1/agent-providers/{{providerId}}/credentials
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "credentialType": "codex_api_key",
  "secret": "replace-with-codex-secret",
  "metadata": {
    "authScheme": "bearer",
    "environmentVariable": "CODEX_API_KEY"
  }
}

### Create Claude API Key Credential
POST {{baseUrl}}/api/v1/agent-providers/{{providerId}}/credentials
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "credentialType": "anthropic_api_key",
  "secret": "replace-with-anthropic-secret",
  "metadata": {
    "authScheme": "api_key",
    "environmentVariable": "ANTHROPIC_API_KEY"
  }
}

