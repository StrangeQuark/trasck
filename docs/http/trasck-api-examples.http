  "externalUrl": "https://example.com/worker/implementation"
}

### Agent Callback
POST {{baseUrl}}/api/v1/agent-callbacks/worker-local
X-Trasck-Agent-Callback-Jwt: {{agentCallbackToken}}
Content-Type: application/json

{
  "status": "completed",
  "message": "Agent finished and requests review.",
  "resultPayload": {
    "summary": "Completed in worker."
  },
  "messages": [
    {
      "senderType": "agent",
      "bodyMarkdown": "Ready for review."
    }
  ],
  "artifacts": [
    {
      "artifactType": "pull_request",
      "name": "Worker pull request",
      "externalUrl": "https://example.com/pull/1"
    }
  ]
}

### Accept Agent Result
POST {{baseUrl}}/api/v1/agent-tasks/{{agentTaskId}}/accept-result
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}
