POST {{baseUrl}}/api/v1/agent-tasks/{{agentTaskId}}/request-changes
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "message": "Please add tests before review."
}

### Worker Progress Log
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-workers/worker-local/tasks/{{agentTaskId}}/logs
X-Trasck-Worker-Token: {{agentWorkerToken}}
Content-Type: application/json

{
  "workerId": "local-worker-1",
  "eventType": "worker_progress",
  "severity": "info",
  "message": "Tests are running."
}

### Worker Adds Artifact
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-workers/worker-local/tasks/{{agentTaskId}}/artifacts
X-Trasck-Worker-Token: {{agentWorkerToken}}
Content-Type: application/json

{
  "artifactType": "branch",
