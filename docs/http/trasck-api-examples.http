{}

### Create Agent Profile
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agents
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "providerId": "{{providerId}}",
  "displayName": "Worker Agent",
  "username": "worker-agent",
  "maxConcurrentTasks": 1,
  "projectIds": [
    "{{projectId}}"
  ]
}

### Add Repository Connection
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/repository-connections
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "projectId": "{{projectId}}",
  "provider": "generic_git",
  "name": "Trasck Backend",
  "repositoryUrl": "https://github.com/StrangeQuark/trasck.git",
  "defaultBranch": "main",
  "providerMetadata": {
    "webUrl": "https://github.com/StrangeQuark/trasck"
  }
}

### Assign Work Item To Agent
POST {{baseUrl}}/api/v1/work-items/{{workItemId}}/assign-agent
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "agentProfileId": "{{profileId}}",
  "repositoryConnectionIds": [
    "{{repositoryConnectionId}}"
  ],
  "requestPayload": {
    "instructions": "Implement the story and request review."
  }
}

### List CLI Worker Run Artifacts
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-cli-runs
Authorization: Bearer {{accessToken}}

### Download CLI Worker Run ZIP
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-cli-runs/{{agentTaskId}}/download
Authorization: Bearer {{accessToken}}

### Delete CLI Worker Run Directory
DELETE {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-cli-runs/{{agentTaskId}}
Authorization: Bearer {{accessToken}}

### Prune Old CLI Worker Run Directories
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-cli-runs/prune
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "retentionDays": 7
}

### Build Backend Push Dispatch Payload
POST {{baseUrl}}/api/v1/agent-tasks/{{agentTaskId}}/worker-dispatch
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Worker Polls For A Task
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-workers/worker-local/tasks/claim
X-Trasck-Worker-Token: {{agentWorkerToken}}
Content-Type: application/json

{
  "workerId": "local-worker-1",
  "capabilities": [
    "code"
  ]
}

### Worker Heartbeat
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/agent-workers/worker-local/tasks/{{agentTaskId}}/heartbeat
X-Trasck-Worker-Token: {{agentWorkerToken}}
Content-Type: application/json

{
  "workerId": "local-worker-1",
  "status": "waiting_for_input",
  "message": "Need clarification."
}

