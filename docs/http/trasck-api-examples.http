@baseUrl = http://localhost:6100
@accessToken = replace-with-login-access-token
@apiToken = replace-with-personal-or-service-token
@csrfToken = replace-with-csrf-token
@organizationId = replace-with-organization-id
@workspaceId = replace-with-workspace-id
@projectId = replace-with-project-id
@programId = replace-with-program-id
@roleId = replace-with-workspace-role-id
@invitationId = replace-with-invitation-id
@userId = replace-with-user-id
@teamId = replace-with-team-id
@iterationId = replace-with-iteration-id
@workItemId = replace-with-work-item-id
@notificationId = replace-with-notification-id
@commentId = replace-with-comment-id
@workLogId = replace-with-work-log-id
@attachmentId = replace-with-attachment-id
@exportJobId = replace-with-export-job-id
@dashboardId = replace-with-dashboard-id
@dashboardWidgetId = replace-with-dashboard-widget-id
@savedFilterId = replace-with-saved-filter-id
@reportQueryId = replace-with-report-query-id
@providerId = replace-with-agent-provider-id
@credentialId = replace-with-agent-provider-credential-id
@profileId = replace-with-agent-profile-id
@repositoryConnectionId = replace-with-repository-connection-id
@agentTaskId = replace-with-agent-task-id
@agentCallbackToken = replace-with-agent-callback-token
@agentWorkerToken = replace-with-worker-token
@cursor = replace-with-next-cursor

### Health
GET {{baseUrl}}/api/trasck/health

### OpenAPI
GET {{baseUrl}}/v3/api-docs

### Swagger UI
GET {{baseUrl}}/swagger-ui.html

### First Setup
POST {{baseUrl}}/api/v1/setup
Content-Type: application/json

{
  "adminUser": {
    "email": "admin@example.com",
    "username": "admin",
    "displayName": "Admin User",
    "password": "correct-horse-battery-staple"
  }
}

### Login And Capture Bearer JWT
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "identifier": "admin@example.com",
  "password": "correct-horse-battery-staple"
}

### Create Organization
POST {{baseUrl}}/api/v1/organizations
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Trasck Local",
  "slug": "trasck-local"
}

### Create Workspace
POST {{baseUrl}}/api/v1/organizations/{{organizationId}}/workspaces
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Trasck Workspace",
  "key": "TR",
  "timezone": "America/Chicago",
  "locale": "en-US",
  "anonymousReadEnabled": false
}

### Create Project
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/projects
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Trasck Project",
  "key": "TRP",
  "description": "Local project",
  "visibility": "private"
}

### Get CSRF Token For Cookie-Authenticated Browser Calls
GET {{baseUrl}}/api/v1/auth/csrf

### Cookie + CSRF Example: Create Work Item
POST {{baseUrl}}/api/v1/projects/{{projectId}}/work-items
Content-Type: application/json
X-XSRF-TOKEN: {{csrfToken}}

{
  "typeKey": "story",
  "title": "Cookie-authenticated story",
  "descriptionMarkdown": "This request uses the login cookie plus CSRF."
}

### Bearer JWT Example: Current User
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{accessToken}}

### Create Workspace Invitation
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/invitations
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "invitee@example.com",
  "roleId": "{{roleId}}"
}

### Revoke Pending Workspace Invitation
DELETE {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/invitations/{{invitationId}}
Authorization: Bearer {{accessToken}}

### Create Workspace User
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/users
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "member@example.com",
  "username": "member",
  "displayName": "Member User",
  "password": "correct-horse-battery-staple",
  "roleId": "{{roleId}}",
  "emailVerified": true
}

### Remove Workspace User
DELETE {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/users/{{userId}}
Authorization: Bearer {{accessToken}}

### Create Personal API Token
POST {{baseUrl}}/api/v1/auth/tokens/personal
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Local REST Client",
  "scopes": [
    "workspace.read",
    "project.read",
    "work_item.read",
    "work_item.create",
    "work_item.update",
    "work_item.comment",
    "work_item.link",
    "work_log.create_own",
    "work_log.update_own",
    "work_log.delete_own",
    "report.read",
    "agent.provider.manage",
    "agent.provider.credential.manage",
    "agent.profile.manage",
    "agent.assign",
    "agent.task.view",
    "agent.task.accept_result",
    "repository_connection.manage"
  ]
}

### API Token Example: List Work Items Cursor Page
GET {{baseUrl}}/api/v1/projects/{{projectId}}/work-items?limit=50
Authorization: Bearer {{apiToken}}

### API Token Example: Next Work Items Page
GET {{baseUrl}}/api/v1/projects/{{projectId}}/work-items?limit=50&cursor={{cursor}}
Authorization: Bearer {{apiToken}}

### Workspace Security Policy
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/security-policy
Authorization: Bearer {{accessToken}}

### Enable Workspace Anonymous Read
PATCH {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/security-policy
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "anonymousReadEnabled": true
}

### Project Security Policy
GET {{baseUrl}}/api/v1/projects/{{projectId}}/security-policy
Authorization: Bearer {{accessToken}}

### Make Project Public
PATCH {{baseUrl}}/api/v1/projects/{{projectId}}/security-policy
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "visibility": "public"
}

### Anonymous Public Project Read
GET {{baseUrl}}/api/v1/public/projects/{{projectId}}

### Create Work Item With Bearer JWT
POST {{baseUrl}}/api/v1/projects/{{projectId}}/work-items
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "typeKey": "story",
  "title": "Implement project hierarchy",
  "descriptionMarkdown": "Define organizations, workspaces, projects, epics, stories, and tasks.",
  "estimatePoints": 5,
  "estimateMinutes": 480,
  "remainingMinutes": 480
}

### Get Work Item
GET {{baseUrl}}/api/v1/work-items/{{workItemId}}
Authorization: Bearer {{accessToken}}

### Work Item Activity Cursor Page
GET {{baseUrl}}/api/v1/work-items/{{workItemId}}/activity?limit=50
Authorization: Bearer {{accessToken}}

### Project Activity Cursor Page
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/projects/{{projectId}}/activity?limit=50
Authorization: Bearer {{accessToken}}

### Workspace Activity Cursor Page
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/activity?limit=50
Authorization: Bearer {{accessToken}}

### Update Work Item
PATCH {{baseUrl}}/api/v1/work-items/{{workItemId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Implement project hierarchy and reporting",
  "remainingMinutes": 360
}

### Transition Work Item
POST {{baseUrl}}/api/v1/work-items/{{workItemId}}/transition
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "transitionKey": "open_to_ready"
}

### Add Comment
POST {{baseUrl}}/api/v1/work-items/{{workItemId}}/comments
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "bodyMarkdown": "This is ready for technical review.",
  "visibility": "workspace"
}

### Update Comment
PATCH {{baseUrl}}/api/v1/work-items/{{workItemId}}/comments/{{commentId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "bodyMarkdown": "Updated review note."
}

### Add Work Log For Yourself
POST {{baseUrl}}/api/v1/work-items/{{workItemId}}/work-logs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "minutesSpent": 60,
  "workDate": "2026-04-19",
  "descriptionMarkdown": "Initial implementation pass."
}

### Update Your Work Log
PATCH {{baseUrl}}/api/v1/work-items/{{workItemId}}/work-logs/{{workLogId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "minutesSpent": 75
}

### Add Watcher For Yourself
POST {{baseUrl}}/api/v1/work-items/{{workItemId}}/watchers
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Create Direct Notification For Workspace Member
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/notifications
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "userId": "{{userId}}",
  "type": "direct",
  "title": "Review requested",
  "body": "Please review the linked work item.",
  "targetType": "work_item",
  "targetId": "{{workItemId}}"
}

### List My Notifications
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/notifications
Authorization: Bearer {{accessToken}}

### Mark Notification Read
PATCH {{baseUrl}}/api/v1/notifications/{{notificationId}}/read
Authorization: Bearer {{accessToken}}

### Add Attachment Metadata
POST {{baseUrl}}/api/v1/work-items/{{workItemId}}/attachments
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "filename": "notes.md",
  "contentType": "text/markdown",
  "storageKey": "manual/notes.md",
  "sizeBytes": 128,
  "checksum": "sha256:replace-with-real-checksum",
  "visibility": "restricted"
}

### Download Attachment Bytes
GET {{baseUrl}}/api/v1/work-items/{{workItemId}}/attachments/{{attachmentId}}/download
Authorization: Bearer {{accessToken}}

### Reporting: Status History
GET {{baseUrl}}/api/v1/reports/work-items/{{workItemId}}/status-history
Authorization: Bearer {{accessToken}}

### Reporting: Assignment History
GET {{baseUrl}}/api/v1/reports/work-items/{{workItemId}}/assignment-history
Authorization: Bearer {{accessToken}}

### Reporting: Estimate History
GET {{baseUrl}}/api/v1/reports/work-items/{{workItemId}}/estimate-history
Authorization: Bearer {{accessToken}}

### Reporting: Work Log Summary
GET {{baseUrl}}/api/v1/reports/work-items/{{workItemId}}/work-log-summary
Authorization: Bearer {{accessToken}}

### Reporting: Project Dashboard Summary
GET {{baseUrl}}/api/v1/reports/projects/{{projectId}}/dashboard-summary?from=2026-04-18T00:00:00Z&to=2026-04-20T00:00:00Z
Authorization: Bearer {{accessToken}}

### Reporting: Team Iteration Dashboard Summary
GET {{baseUrl}}/api/v1/reports/projects/{{projectId}}/dashboard-summary?from=2026-04-18T00:00:00Z&to=2026-04-20T00:00:00Z&teamId={{teamId}}&iterationId={{iterationId}}
Authorization: Bearer {{accessToken}}

### Create Program
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/programs
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Delivery Platform",
  "description": "Cross-project delivery program",
  "status": "active",
  "roadmapConfig": {
    "horizon": "quarter"
  },
  "reportConfig": {
    "defaultGranularity": "weekly"
  }
}

### List Programs
GET {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/programs
Authorization: Bearer {{accessToken}}

### Assign Project To Program
PUT {{baseUrl}}/api/v1/programs/{{programId}}/projects/{{projectId}}
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "position": 0
}

### Reporting: Program Dashboard Summary
GET {{baseUrl}}/api/v1/reports/programs/{{programId}}/dashboard-summary?from=2026-04-18T00:00:00Z&to=2026-04-20T00:00:00Z
Authorization: Bearer {{accessToken}}

### Reporting: Run Workspace Snapshots
POST {{baseUrl}}/api/v1/reports/workspaces/{{workspaceId}}/snapshots/run?date=2026-04-19
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Reporting: Backfill Workspace Snapshots
POST {{baseUrl}}/api/v1/reports/workspaces/{{workspaceId}}/snapshots/backfill?fromDate=2026-04-19&toDate=2026-04-25
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Reporting: Get Snapshot Retention Policy
GET {{baseUrl}}/api/v1/reports/workspaces/{{workspaceId}}/snapshot-retention-policy
Authorization: Bearer {{accessToken}}

### Reporting: Update Snapshot Retention Policy
PUT {{baseUrl}}/api/v1/reports/workspaces/{{workspaceId}}/snapshot-retention-policy
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "rawRetentionDays": 730,
  "weeklyRollupAfterDays": 90,
  "monthlyRollupAfterDays": 365,
  "archiveAfterDays": 1825,
  "destructivePruningEnabled": false
}

### Reporting: Backfill Snapshot Rollups
POST {{baseUrl}}/api/v1/reports/workspaces/{{workspaceId}}/snapshots/rollups/backfill?fromDate=2026-04-19&toDate=2026-04-25&granularity=daily
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{}

### Reporting: Project Snapshot Series
GET {{baseUrl}}/api/v1/reports/projects/{{projectId}}/snapshots?fromDate=2026-04-19&toDate=2026-04-25
Authorization: Bearer {{accessToken}}

### Create Project Saved Filter
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/saved-filters
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Committed project work",
  "visibility": "project",
  "projectId": "{{projectId}}",
  "query": {
    "projectId": "{{projectId}}",
    "teamId": "{{teamId}}",
    "iterationId": "{{iterationId}}"
  }
}

### Create Governed Report Query
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/report-query-catalog
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "queryKey": "committed-project-work",
  "name": "Committed project work",
  "queryType": "project_dashboard_summary",
  "visibility": "project",
  "projectId": "{{projectId}}",
  "queryConfig": {
    "savedFilterId": "{{savedFilterId}}"
  },
  "parametersSchema": {
    "type": "object",
    "required": ["projectId", "teamId", "iterationId"],
    "additionalProperties": false,
    "properties": {
      "projectId": { "type": "uuid" },
      "teamId": { "type": "uuid" },
      "iterationId": { "type": "uuid" }
    }
  }
}

### Create Project Dashboard
POST {{baseUrl}}/api/v1/workspaces/{{workspaceId}}/dashboards
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Project Delivery",
  "visibility": "project",
  "projectId": "{{projectId}}",
  "layout": {
    "columns": 12,
    "density": "comfortable"
  }
}

### Add Dashboard Widget From Report Query
POST {{baseUrl}}/api/v1/dashboards/{{dashboardId}}/widgets
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "widgetType": "work_item_summary",
  "title": "Committed Work",
  "positionX": 0,
  "positionY": 0,
  "width": 4,
  "height": 2,
  "config": {
    "reportQueryId": "{{reportQueryId}}"
  }
}

### Render Dashboard
GET {{baseUrl}}/api/v1/dashboards/{{dashboardId}}/render?from=2026-04-18T00:00:00Z&to=2026-04-20T00:00:00Z
Authorization: Bearer {{accessToken}}

